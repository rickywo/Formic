# Formic — Environment Configuration
# Copy this file to .env and adjust values for your setup.

# === Agent Selection ===
# Initial agent CLI type: 'claude', 'copilot', or 'opencode' (default: claude).
# This is a fallback — the Kanban UI header provider switcher takes precedence
# once a selection is made. Precedence: UI setting > AGENT_TYPE > claude.
AGENT_TYPE=claude
# Per-step model selection is configured in the UI (Settings → Agent Models), not via env vars.

# Optional: override the agent binary path (e.g. a custom build or absolute path)
# AGENT_COMMAND=claude

# === Claude Code CLI (default agent) ===
ANTHROPIC_API_KEY=sk-ant-...

# === GitHub Copilot CLI ===
# AGENT_TYPE=copilot
# No API key required — uses GitHub OAuth. Run `gh auth login` first.

# === OpenCode CLI ===
# AGENT_TYPE=opencode
# AGENT_COMMAND=opencode
# OpenCode uses provider keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.) or
# its built-in OAuth flow. Run `opencode auth login` to set up credentials.
# Recommended for headless/CI stability — disables auto-update checks:
# OPENCODE_DISABLE_AUTOUPDATE=1

# === Server ===
PORT=8000
HOST=127.0.0.1

# Required when binding to a non-loopback host (HOST=0.0.0.0):
# FORMIC_AUTH_TOKEN=your-secret-token

# === Messaging Webhooks ===
# Required when using Telegram messaging with webhooks:
# TELEGRAM_BOT_TOKEN=your-bot-token

# Optional: authenticate incoming Telegram webhook updates. If not set, Formic
# generates and persists a random secret on first startup. Telegram echoes this
# value back in the X-Telegram-Bot-Api-Secret-Token header on every update.
# TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# === IMPORTANT ===
# Never commit your .env file to version control. It is gitignored by default.
# All values in this file are examples only — replace them with real secrets
# in your local .env.

# === Queue ===
# Maximum concurrent agent processes (default: 2)
# FORMIC_MAX_CONCURRENT=2

# Disable the queue processor entirely:
# FORMIC_QUEUE_ENABLED=false
