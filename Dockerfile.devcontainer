# ==============================================================================
# Formic — Dev-Container Image (Interactive Development Shell)
# ==============================================================================
# This image is for interactive development — it provides zsh, git, jq, vim,
# and the agent CLIs in a full bookworm environment. It is NOT intended for
# headless deployment; use the runtime image (Dockerfile) for that.
#
# Published under the `-devcontainer` tag alongside the runtime image.
#
# To update the base image digest, run:
#   docker pull node:22-bookworm
#   docker inspect node:22-bookworm --format='{{index .RepoDigests 0}}'
# ==============================================================================

FROM node:22-bookworm@sha256:a25c9934ff6382cd4f08b6bc26c82bf4ea69b1e6f8dabfb2ead457374127c365

# ---------------------------------------------------------------------------
# Build arguments (NOT persisted as env)
# ---------------------------------------------------------------------------
ARG DEBIAN_FRONTEND=noninteractive

# Agent CLI versions — pinned for reproducible builds.
ARG CLAUDE_CODE_VERSION=2.1.207
ARG OPENCODE_AI_VERSION=1.17.18
ARG FORMIC_VERSION=0.9.0

# ---------------------------------------------------------------------------
# OCI labels
# ---------------------------------------------------------------------------
LABEL org.opencontainers.image.source="https://github.com/rickywo/Formic" \
      org.opencontainers.image.version="${FORMIC_VERSION}" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.description="Formic — AI-powered task manager and agent orchestration platform (interactive dev-container)"

# ---------------------------------------------------------------------------
# System dependencies (interactive tooling)
# ---------------------------------------------------------------------------
# hadolint ignore=DL3008
# (pinned base image digest provides reproducibility; apt package version
# pinning would break on Debian point-release mirror churn.)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        zsh \
        jq \
        vim \
        curl \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Starship prompt — installed from a pinned GitHub release binary and verified
# against its published SHA-256. We deliberately do NOT use the upstream
# `curl … | sh` installer (unpinned remote code execution at build time) or
# `sudo` (not present in this image by design). arm64 Linux ships only a musl
# build; x86_64 ships gnu.
# ---------------------------------------------------------------------------
ARG STARSHIP_VERSION=1.26.0
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) target="x86_64-unknown-linux-gnu" ;; \
      arm64) target="aarch64-unknown-linux-musl" ;; \
      *) echo "unsupported architecture: $arch" >&2; exit 1 ;; \
    esac; \
    base="https://github.com/starship/starship/releases/download/v${STARSHIP_VERSION}"; \
    curl -fsSL -o /tmp/starship.tar.gz "${base}/starship-${target}.tar.gz"; \
    curl -fsSL -o /tmp/starship.sha256 "${base}/starship-${target}.tar.gz.sha256"; \
    printf '%s  /tmp/starship.tar.gz\n' "$(cut -d' ' -f1 /tmp/starship.sha256)" | sha256sum -c -; \
    tar -xzf /tmp/starship.tar.gz -C /usr/local/bin starship; \
    rm -f /tmp/starship.tar.gz /tmp/starship.sha256; \
    starship --version

# ---------------------------------------------------------------------------
# Developer user (NO sudoers entry — no NOPASSWD:ALL, no wheel group)
# ---------------------------------------------------------------------------
RUN useradd --create-home --shell /usr/bin/zsh developer

# ---------------------------------------------------------------------------
# Developer home: pre-create the XDG directories the agent CLIs write to and
# ship a .zshrc. Pre-creating the OpenCode mount points (and ~/.local/state)
# as developer-owned stops Docker from auto-creating their parents as root at
# runtime — which is what made ~/.local/state unwritable (EACCES) when the
# host volumes were bind-mounted. Shipping .zshrc also enables the starship
# prompt and suppresses zsh's first-run setup wizard.
# ---------------------------------------------------------------------------
RUN mkdir -p /home/developer/.config/opencode \
             /home/developer/.local/share/opencode \
             /home/developer/.local/state \
             /home/developer/.cache \
    && printf 'eval "$(starship init zsh)"\n' > /home/developer/.zshrc \
    && chown -R developer:developer /home/developer

# ---------------------------------------------------------------------------
# Agent CLIs (globally installed, pinned by exact version)
# ---------------------------------------------------------------------------
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} \
    && npm install -g opencode-ai@${OPENCODE_AI_VERSION} \
    && npm install -g @rickywo/formic@${FORMIC_VERSION}

# ---------------------------------------------------------------------------
# Working directory
# ---------------------------------------------------------------------------
WORKDIR /workspace
RUN chown -R developer:developer /workspace

# ---------------------------------------------------------------------------
# Drop privileges
# ---------------------------------------------------------------------------
USER developer

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
EXPOSE 8000

CMD ["zsh"]

# ---------------------------------------------------------------------------
# Secrets are RUNTIME-ONLY. Never set these at build time:
#   ANTHROPIC_API_KEY, FORMIC_AUTH_TOKEN, TELEGRAM_BOT_TOKEN,
#   TELEGRAM_WEBHOOK_SECRET, LINE_CHANNEL_ACCESS_TOKEN, LINE_CHANNEL_SECRET,
#   OPENAI_API_KEY, DEEPSEEK_API_KEY
# ---------------------------------------------------------------------------
